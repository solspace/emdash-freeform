{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "freeform-demo",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Public hostname. CF auto-provisions DNS + SSL for this on deploy as long
	// as marsroversupply.com is on the same CF account. Worker is reachable
	// here only — workers.dev is disabled because Anthropic's outbound POST
	// allowlist blocks workers.dev domains anyway.
	"workers_dev": false,
	"routes": [
		{
			"pattern": "emdash.marsroversupply.com",
			"custom_domain": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "freeform-demo",
			"database_id": "65cc710d-13bc-4e6a-bec8-5d03257b7fcf",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "freeform-demo-media",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
	// Self-binding so the MCP handler can invoke plugin routes in-process.
	// Cloudflare blocks workers from making HTTP fetches to their own hostname;
	// env.SELF.fetch() dispatches directly to the worker handler instead.
	"services": [
		{
			"binding": "SELF",
			"service": "freeform-demo",
		},
	],
}