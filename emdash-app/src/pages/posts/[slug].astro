---
import { getEmDashEntry, getEntryTerms, getSeoMeta, decodeSlug, getSiteSettings } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category");

const dateFmt = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "short",
	day: "2-digit",
});
const docId = (post.data.id ?? slug).toString().toUpperCase();
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	image={seo.ogImage}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="page post">
		<header class="page-header">
			<div>
				<div class="eyebrow">
					{categories.length > 0 ? (
						<>
							<a href={`/category/${categories[0].slug}`}>{categories[0].label.toUpperCase()}</a>
							<span class="dot">·</span>
							<span>DISPATCH {docId.slice(0, 12)}</span>
						</>
					) : (
						<span>DISPATCH {docId.slice(0, 12)}</span>
					)}
				</div>
				<h1 {...post.edit.title}>{post.data.title}</h1>
			</div>
			{post.data.publishedAt && (
				<time class="page-meta" datetime={post.data.publishedAt.toISOString()}>
					{dateFmt.format(post.data.publishedAt)}
				</time>
			)}
		</header>

		{post.data.featured_image && (
			<div class="post-image" {...post.edit.featured_image}>
				<Image image={post.data.featured_image} />
			</div>
		)}

		<div class="prose">
			<PortableText value={post.data.content} />
		</div>

		{tags.length > 0 && (
			<div class="post-tags">
				<span class="post-tags-label mono">FILED UNDER</span>
				{tags.map((t) => (
					<a href={`/tag/${t.slug}`}>{t.label}</a>
				))}
			</div>
		)}
	</article>
</Base>

<style>
	.post-image {
		margin: 2rem 0;
		border: 1px solid var(--mrs-rule);
	}
	.post-image :global(img) { display: block; width: 100%; height: auto; }

	.eyebrow a {
		color: var(--mrs-accent);
		text-decoration: none;
		letter-spacing: 0.2em;
	}
	.eyebrow .dot { color: var(--mrs-fg-dim); margin: 0 0.5rem; }

	.post-tags {
		margin-top: 3.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--mrs-rule);
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.post-tags-label {
		font-size: 0.6875rem;
		letter-spacing: 0.2em;
		color: var(--mrs-fg-muted);
		text-transform: uppercase;
		margin-right: 0.5rem;
	}
	.post-tags a {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--mrs-fg-muted);
		text-decoration: none;
		padding: 0.25rem 0.625rem;
		border: 1px solid var(--mrs-rule-strong);
	}
	.post-tags a:hover { color: var(--mrs-accent); border-color: var(--mrs-accent); }
</style>
