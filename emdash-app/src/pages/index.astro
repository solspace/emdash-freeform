---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../utils/site-identity";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const { siteTitle, siteTagline } = resolveStarterSiteIdentity(await getSiteSettings());
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const dateFmt = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "short",
	day: "2-digit",
});
---

<Base title={siteTitle} description={siteTagline}>
	<section class="hero">
		<div class="hero-grid">
			<div class="hero-text">
				<div class="hero-eyebrow">
					<span>EST. 2019</span>
					<span class="dot">·</span>
					<span>THARSIS YARD</span>
					<span class="dot">·</span>
					<span>EL SEGUNDO · CA</span>
				</div>
				<h1>
					Engineering<br />
					for the world<br />
					<span class="accent-line">beyond ours.</span>
				</h1>
				<p class="hero-lede">
					Crew-rated and autonomous mobility platforms for surface operations
					on the Moon, Mars, and the analog terrain that proves them out.
					Built to MRS-9100. Delivered on schedule.
				</p>
				<div class="hero-actions">
					<a href="/products" class="btn btn-primary">View products</a>
					<a href="/contact" class="btn btn-ghost">Start a program →</a>
				</div>
			</div>
			<div class="hero-art" aria-hidden="true">
				<img src="/rover.svg" alt="" />
				<div class="hero-art-caption mono">
					<span>FIG. 01</span>
					<span>SCOUT-7 SURVEY (REF.)</span>
				</div>
			</div>
		</div>

		<dl class="hero-stats">
			<div>
				<dt>Platforms shipped</dt>
				<dd>62</dd>
				<dd class="unit">since 2021</dd>
			</div>
			<div>
				<dt>Analog km logged</dt>
				<dd>11,400</dd>
				<dd class="unit">Atacama LRF</dd>
			</div>
			<div>
				<dt>Mission availability</dt>
				<dd>99.7<span class="accent">%</span></dd>
				<dd class="unit">crew-rated fleet</dd>
			</div>
			<div>
				<dt>Response SLA</dt>
				<dd>&lt; 90<span class="unit-inline"> min</span></dd>
				<dd class="unit">anomaly triage</dd>
			</div>
		</dl>
	</section>

	<section class="news">
		<header class="section-head">
			<div class="eyebrow">SECTION 02 · DISPATCH</div>
			<h2>Recent dispatches from the line</h2>
			<a href="/category/news" class="section-more mono">All news →</a>
		</header>

		{posts.length === 0 ? (
			<p>
				No dispatches yet. <a href="/_emdash/admin/content/posts/new">Add one</a>.
			</p>
		) : (
			<ul class="news-list">
				{posts.map((post) => (
					<li class="news-item">
						<a href={`/posts/${post.id}`}>
							<div class="news-meta mono">
								{post.data.publishedAt && (
									<time datetime={post.data.publishedAt.toISOString()}>
										{dateFmt.format(post.data.publishedAt)}
									</time>
								)}
							</div>
							<h3>{post.data.title}</h3>
							{post.data.excerpt && <p>{post.data.excerpt}</p>}
							<span class="news-arrow" aria-hidden="true">→</span>
						</a>
					</li>
				))}
			</ul>
		)}
	</section>
</Base>

<style>
	.hero {
		max-width: 1180px;
		margin: 0 auto;
		padding: 4rem 1.5rem 5rem;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 3rem;
		align-items: center;
	}
	.hero-eyebrow {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--mrs-fg-muted);
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-bottom: 2rem;
	}
	.hero-eyebrow .dot { color: var(--mrs-fg-dim); }

	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		line-height: 1.05;
		letter-spacing: 0.02em;
		margin: 0 0 2rem;
	}
	.accent-line {
		color: var(--mrs-accent);
		display: inline-block;
		border-bottom: 4px solid var(--mrs-accent);
		padding-bottom: 0.15em;
	}
	.hero-lede {
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--mrs-fg-muted);
		max-width: 36ch;
		margin: 0 0 2.5rem;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.btn {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 0.875rem 1.5rem;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		transition: background 0.18s, color 0.18s, border-color 0.18s;
	}
	.btn-primary {
		background: var(--mrs-accent);
		color: var(--mrs-fg);
		border: 1px solid var(--mrs-accent);
	}
	.btn-primary:hover { background: transparent; color: var(--mrs-accent); }
	.btn-ghost {
		background: transparent;
		color: var(--mrs-fg);
		border: 1px solid var(--mrs-rule-strong);
	}
	.btn-ghost:hover { border-color: var(--mrs-accent); color: var(--mrs-accent); }

	.hero-art {
		position: relative;
		padding: 1rem;
		border: 1px solid var(--mrs-rule);
		background:
			linear-gradient(135deg, transparent 49%, var(--mrs-rule) 49%, var(--mrs-rule) 51%, transparent 51%) 0 0 / 6px 6px,
			var(--mrs-bg-elev);
		background-blend-mode: normal;
	}
	.hero-art img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 420px;
		object-fit: contain;
	}
	.hero-art-caption {
		display: flex;
		justify-content: space-between;
		font-size: 0.6875rem;
		letter-spacing: 0.2em;
		color: var(--mrs-fg-muted);
		text-transform: uppercase;
		padding-top: 0.75rem;
		margin-top: 0.5rem;
		border-top: 1px solid var(--mrs-rule);
	}

	.hero-stats {
		margin: 4rem 0 0;
		padding: 1.75rem 0 0;
		border-top: 1px solid var(--mrs-rule-strong);
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
	}
	.hero-stats > div {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.hero-stats dt {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--mrs-fg-muted);
		margin: 0;
	}
	.hero-stats dd {
		font-family: var(--font-display);
		font-size: 2rem;
		line-height: 1;
		margin: 0.25rem 0 0;
		color: var(--mrs-fg);
	}
	.hero-stats dd.unit {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.16em;
		color: var(--mrs-fg-dim);
		text-transform: uppercase;
		margin-top: 0.25rem;
	}
	.unit-inline {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		color: var(--mrs-fg-muted);
		letter-spacing: 0.1em;
	}

	.news {
		max-width: 1180px;
		margin: 0 auto;
		padding: 4rem 1.5rem 2rem;
		border-top: 1px solid var(--mrs-rule);
	}
	.section-head {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: end;
		gap: 2rem;
		margin-bottom: 2.5rem;
	}
	.section-head .eyebrow {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--mrs-accent);
		grid-column: 1;
	}
	.section-head h2 {
		grid-column: 1;
		margin: 0.5rem 0 0;
	}
	.section-more {
		grid-column: 2;
		grid-row: 1 / span 2;
		align-self: end;
		justify-self: end;
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--mrs-fg-muted);
		text-decoration: none;
		padding-bottom: 0.25rem;
		border-bottom: 1px solid var(--mrs-rule-strong);
	}
	.section-more:hover { color: var(--mrs-accent); border-bottom-color: var(--mrs-accent); }

	.news-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--mrs-rule);
		border: 1px solid var(--mrs-rule);
	}
	.news-item { background: var(--mrs-bg); }
	.news-item a {
		display: block;
		padding: 1.75rem 1.75rem 2rem;
		text-decoration: none;
		color: inherit;
		position: relative;
		transition: background 0.18s;
		height: 100%;
	}
	.news-item a:hover { background: var(--mrs-bg-elev); }
	.news-item a:hover .news-arrow { color: var(--mrs-accent); transform: translateX(4px); }

	.news-meta {
		font-size: 0.6875rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--mrs-fg-dim);
		margin-bottom: 1rem;
	}
	.news-item h3 {
		font-family: var(--font-display);
		font-size: 1.0625rem;
		line-height: 1.3;
		letter-spacing: 0.02em;
		margin: 0 0 0.75rem;
		color: var(--mrs-fg);
	}
	.news-item p {
		font-size: 0.875rem;
		line-height: 1.55;
		color: var(--mrs-fg-muted);
		margin: 0;
		max-width: none;
	}
	.news-arrow {
		position: absolute;
		right: 1.75rem;
		bottom: 1.5rem;
		font-family: var(--font-mono);
		color: var(--mrs-fg-dim);
		transition: color 0.18s, transform 0.18s;
	}

	@media (max-width: 820px) {
		.hero-grid { grid-template-columns: 1fr; }
		.hero-stats { grid-template-columns: repeat(2, 1fr); }
		.news-list { grid-template-columns: 1fr; }
		.section-head { grid-template-columns: 1fr; }
		.section-more { grid-column: 1; grid-row: auto; justify-self: start; margin-top: 0.5rem; }
	}
</style>
