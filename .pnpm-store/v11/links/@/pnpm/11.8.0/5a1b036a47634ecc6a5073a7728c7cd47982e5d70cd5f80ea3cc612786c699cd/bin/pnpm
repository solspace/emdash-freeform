#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.mjs" "$@"
fi
# cmd-shim-target=/Users/thejahid/solspace/emdash-freeform/.pnpm-store/v11/links/@/pnpm/11.8.0/5a1b036a47634ecc6a5073a7728c7cd47982e5d70cd5f80ea3cc612786c699cd/node_modules/pnpm/bin/pnpm.mjs
